<Window x:Class="SolidWorksNativeHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SolidWorksNativeHost"
        Title="SolidWorks AI CAD Studio Host"
        Width="1440"
        Height="900"
        MinWidth="1000"
        MinHeight="680"
        Background="#eef2f0">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="#24383d" Padding="12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="DashboardUrlBox"
                 Grid.Column="0"
                 MinHeight="34"
                 Margin="0,0,8,0"
                 VerticalContentAlignment="Center" />
        <Button Grid.Column="1"
                MinWidth="112"
                Margin="0,0,8,0"
                Padding="12,6"
                Click="NavigateDashboard_Click">
          Open dashboard
        </Button>
        <Button Grid.Column="2"
                MinWidth="132"
                Padding="12,6"
                Click="AttachSolidWorks_Click">
          Attach SolidWorks
        </Button>
      </Grid>
    </Border>

    <Grid Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="0.95*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="1.35*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" BorderBrush="#aebbb7" BorderThickness="1" Background="White">
        <local:EdgeDashboardHwndHost x:Name="DashboardHost" />
      </Border>

      <GridSplitter Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#cdd6d3" />

      <Border Grid.Column="2" BorderBrush="#aebbb7" BorderThickness="1" Background="#172225">
        <local:SolidWorksHwndHost x:Name="SolidWorksHost" />
      </Border>
    </Grid>
  </DockPanel>
</Window>
